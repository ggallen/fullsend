# Containerfile — sandbox image for the runner-hello-world experiment.
#
# Extends the base fullsend sandbox image with experiment-specific tools.
# See images/sandbox/Containerfile for the base image definition.
#
# Build (two-step):
#   1. Build the base image first:
#      podman build -t fullsend-sandbox:latest \
#        -f images/sandbox/Containerfile images/sandbox/
#   2. Build this experiment image:
#      podman build -t quay.io/manonru/fullsend-exp:v1 \
#        --build-arg BASE_IMAGE=fullsend-sandbox:latest \
#        -f experiments/runner-hello-world/experiment/Containerfile \
#        experiments/runner-hello-world/experiment/

ARG BASE_IMAGE=fullsend-sandbox:latest
FROM ${BASE_IMAGE}

USER root

# Copy experiment tool binaries.
COPY tools/hello-world-bin /usr/local/bin/hello-world-bin
RUN chmod +x /usr/local/bin/hello-world-bin

# Switch back to the sandbox user.
USER sandbox
